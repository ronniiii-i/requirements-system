# ============================================================
#  .env.example — Copy this to .env and fill in your values
# ============================================================

# ---- LOCAL DEVELOPMENT ----
DB_URL=postgresql://postgres:yourpassword@localhost:5432/reqgen_db

# ---- SUPABASE (paste your connection string from dashboard) ----
# DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ---- RAILWAY ----
# DB_URL=postgresql://postgres:[PASSWORD]@[HOST].railway.app:[PORT]/railway

# ---- RENDER ----
# DB_URL=postgresql://[USER]:[PASSWORD]@[HOST]/[DBNAME]

# ---- APP SETTINGS ----
APP_ENV=development          # development | production
SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000

# ---- NLP / HUGGINGFACE ----
HF_SPACE_URL=https://your-username-your-space.hf.space
HF_API_TOKEN=                # Optional — only if your Space is private

# ---- RASA ----
RASA_SERVER_URL=http://localhost:5005
